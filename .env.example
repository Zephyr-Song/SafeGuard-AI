# SafeGuard AI 环境变量配置
# 复制此文件为 .env 并填写你的API密钥

# ========== 选择使用的模型 ==========
# 可选值: openai (Gemini) 或 zhipu (智谱AI)
ACTIVE_MODEL=openai

# ========== Google Gemini API (OpenAI兼容) ==========
# 获取API密钥: https://makersuite.google.com/app/apikey
OPENAI_API_KEY=your_gemini_api_key_here

# ========== 智谱AI (GLM-4) ==========
# 获取API密钥: https://open.bigmodel.cn/
ZHI_KEY=your_zhipu_api_key_here

# ========== 模拟模式 ==========
# 设置为True时，不调用真实API，使用模拟数据
MOCK_MODE=False

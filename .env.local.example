# SafeBARS local API key config
# Copy this file to `.env.local`, then fill in your own keys.
# `.env.local` is ignored by git and should not be shared.

# Zhipu
ZHI_KEY=
ZHI_MODEL=glm-4

# Aliyun Bailian / DashScope
BAILIAN_API_KEY=
BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
BAILIAN_MODEL=qwen-plus

# Tencent TokenHub / Hunyuan-compatible chat completions
TENCENT_API_KEY=
TENCENT_BASE_URL=https://tokenhub.tencentmaas.com/v1
TENCENT_MODEL=hy3-preview
TENCENT_LABEL=Tencent TokenHub HY3 Preview

# Xunfei MaaS / Spark-compatible HTTP API
XFYUN_MAAS_API_KEY=
XFYUN_MAAS_BASE_URL=https://maas-api.cn-huabei-1.xf-yun.com/v2
XFYUN_MAAS_MODEL=xopdeepseekv4flash
XFYUN_MAAS_LABEL=Xunfei MaaS DeepSeek V4 Flash

# OpenAI/GPT provider is intentionally not included in this local config.
